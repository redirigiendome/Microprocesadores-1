.include "m328pdef.inc"

.org 0x00
rjmp inicio

inicio:
    ldi r16, 0x7F
    out DDRD, r16

loop:
    ldi ZH, high(tabla<<1)
    ldi ZL, low(tabla<<1)

    ldi r18, 10

siguiente:
    lpm r17, Z+
    out PORTD, r17
    rcall delay

    dec r18
    brne siguiente

    rjmp loop

tabla:
.db 0b00111111
.db 0b00000110
.db 0b01011011
.db 0b01001111
.db 0b01100110
.db 0b01101101
.db 0b01111101
.db 0b00000111
.db 0b01111111
.db 0b01101111

delay:
    ldi r20, 100
d1:
    ldi r21, 200
d2:
    dec r21
    brne d2
    dec r20
    brne d1
    ret
