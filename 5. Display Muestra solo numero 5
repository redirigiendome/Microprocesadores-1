.include "m328pdef.inc"     ; Definiciones del ATmega328P

.org 0x00                   ; Vector de reset
rjmp inicio                 ; Salta al inicio del programa

inicio:
    ldi r16, 0x7F           ; r16 = 0b01111111 -> PD0 a PD6 como salida, PD7 como entrada

    out DDRD, r16           ; Configura los pines PD0–PD6 como salidas (para el display)

    ; numero 5
    ldi r17, 0b01101101     ; Patron de segmentos para mostrar el numero 5
                            ; (depende del orden de conexion: a,b,c,d,e,f,g)

    out PORTD, r17          ; Envia el patron al puerto D (enciende/apaga segmentos)

loop:
    rjmp loop               ; Bucle infinito (mantiene el numero fijo)
