;MISMA CONEXION QUE EL PRIMER ARCHIVO- "PRENDER SOLO 1 LED"

.include "m328pdef.inc"     ; Definiciones del ATmega328P (registros, bits, etc.)

.equ PIN_LED = 5            ; LED conectado al bit 5 del PORTB (PB5)
.equ D1 = 100               ; Constante para retardo externo (bucle grande)
.equ D2 = 200               ; Constante para retardo interno (bucle pequeño)

.org 0x00                   ; Direccion de inicio del programa (reset)
rjmp inicio                 ; Salta al inicio del programa

inicio:
    ldi r16, (1<<PIN_LED)  ; r16 = 0b00100000 -> activa solo PB5

    out DDRB, r16          ; Configura PB5 como salida (OJO: los demas pines quedan como entrada)

loop:
    sbi PORTB, PIN_LED     ; Enciende el LED (pone PB5 en alto)
    rcall delay            ; Llama a la subrutina de retardo

    cbi PORTB, PIN_LED     ; Apaga el LED (pone PB5 en bajo)
    rcall delay            ; Otro retardo

    rjmp loop              ; Bucle infinito

; -------------------------
; SUBRUTINA DE RETARDO
; -------------------------
delay:
    ldi r18, D1            ; Contador externo (controla duracion total)

d1:
    ldi r19, D2            ; Contador interno (bucle mas rapido)

d2:
    dec r19                ; Decrementa r19
    brne d2                ; Si no es cero, repite bucle interno

    dec r18                ; Decrementa contador externo
    brne d1                ; Si no es cero, repite todo el bloque

    ret                    ; Regresa a donde se llamo (rcall)
